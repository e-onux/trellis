{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/e-onux/trellis/main/standard/schemas/source.schema.json",
  "title": "Trellis Source Record",
  "description": "A piece of evidence (paper, benchmark, doc, standard, incident…) linked to the decisions and capabilities it supports. Forms the evidence graph.",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "supports"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^source-[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "published": {
      "type": [
        "integer",
        "string"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "academic-paper",
        "standard",
        "official-documentation",
        "security-advisory",
        "benchmark",
        "experiment",
        "internal-evaluation",
        "user-research",
        "incident-report",
        "regulation",
        "rfc",
        "proof-of-concept"
      ]
    },
    "doi": {
      "type": "string"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string",
      "description": "Source license. Drives whether a local copy may be stored."
    },
    "local_copy": {
      "description": "Default null. A local PDF/DOCX is only stored when the license/permission allows it.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "type": [
                "string",
                "null"
              ]
            },
            "sha256": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      ]
    },
    "supports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "ADR ids and/or capability ids this source backs."
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "confidence": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "relevance": {
      "type": "object",
      "properties": {
        "claim": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "last_verified": {
      "type": "string",
      "format": "date"
    },
    "next_review": {
      "type": "string",
      "format": "date"
    }
  }
}
